{
  "realm": "task-manager",
  "enabled": true,
  "displayName": "Task Manager Local Realm",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standard task manager user"
      },
      {
        "name": "ADMIN",
        "description": "Task manager administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "task-manager-api",
      "name": "task-manager-api",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    }
  ],
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "UserOne",
      "email": "user1@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "user1pass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER"
      ]
    },
    {
      "username": "user2",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Local",
      "lastName": "UserTwo",
      "email": "user2@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "user2pass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "USER",
        "ADMIN"
      ]
    }
  ]
}
